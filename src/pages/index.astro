---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Wilfried Lafaye | AI & Data Science Portfolio" description="Portfolio of Wilfried Lafaye. A Data Scientist & AI Engineer building the next generation of intelligent systems through interactive dashboards, AI models, and web applications.">
	<section id="hero" class="hero-section">
      <div class="hero-content">
        <span class="badge">Portfolio 2026</span>
        <h1>Crafting Intelligence <br> <span class="text-gradient">with Data & Code</span></h1>
        <p>Hi, I'm <strong>Wilfried Lafaye</strong>. <br> A Data Scientist & AI Engineer building the next generation of
          intelligent systems.</p>
        <div class="hero-actions">
          <a href="/projects.html" class="btn-primary">View Work</a>
          <a href="https://github.com/wilfried-lafaye" target="_blank" class="btn-secondary">GitHub</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="glow-orb"></div>
      </div>
    </section>

    <section id="projects" class="section">
      <div class="section-header">
        <h2>Featured Projects</h2>
        <p>Interactive dashboards, AI models, and web applications.</p>
      </div>
      <div id="projects-list" class="grid-container">
        <!-- Javascript will populate this -->
      </div>
    </section>

    <section id="experience" class="section">
      <div class="section-header">
        <h2>Experience</h2>
      </div>
      <div id="experience-list" class="parallel-timeline">
        <!-- Javascript will populate this -->
      </div>
    </section>

    <section id="education" class="section">
      <div class="section-header">
        <h2>Education</h2>
      </div>
      <div id="education-list" class="timeline-container">
        <!-- Javascript will populate this -->
      </div>
    </section>

    <section id="skills" class="section">
      <div class="section-header">
        <h2>Tech Stack</h2>
      </div>
      <div id="skills-list" class="skills-cloud">
        <!-- Javascript will populate this -->
      </div>
    </section>

    <section id="contact" class="section">
      <div class="centered glass">
        <h2>Get In Touch</h2>
        <p style="color: var(--text-secondary); margin-top: 1rem;">Interested in collaborating or just want to say hi? Feel free to reach out.</p>
        <div class="contact-links">
          <a href="mailto:wilfried.music@icloud.com" class="contact-item btn-secondary" aria-label="Send email">📧 Email</a>
          <a href="https://github.com/wilfried-lafaye" target="_blank" class="contact-item btn-secondary" aria-label="View GitHub profile">💻 GitHub</a>
          <a href="https://linkedin.com/in/wilfried-lafaye" target="_blank" class="contact-item btn-secondary" aria-label="View LinkedIn profile">🔗 LinkedIn</a>
        </div>
      </div>
    </section>

	<script src="/js/components/projects.js" defer is:inline></script>
    <script src="/js/components/experience.js?v=2" defer is:inline></script>
    <script src="/js/components/education.js" defer is:inline></script>
    <script src="/js/components/skills.js" defer is:inline></script>
</Layout>

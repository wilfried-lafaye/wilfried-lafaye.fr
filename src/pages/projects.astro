---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Projects | Wilfried Lafaye" description="Explore the portfolio projects of Wilfried Lafaye. A collection of work ranging from personal experiments in AI and Data Science to educational assignments.">
	<section class="hero-section" style="min-height: 40vh; padding-top: 8rem;">
      <div class="hero-content" style="text-align: center; max-width: 800px; margin: 0 auto;">
        <h1>Explore My <span class="text-gradient">Projects</span></h1>
        <p>A collection of my work, ranging from personal experiments to educational assignments.</p>
      </div>
    </section>

    <section class="section">
      <!-- Filters & Search -->
      <div class="filters-section">
        <input type="text" id="search-input" class="search-bar" placeholder="Search projects...">
        <div class="filter-buttons">
          <button class="filter-btn active" data-filter="all">All</button>
          <button class="filter-btn" data-filter="personal">Personal</button>
          <button class="filter-btn" data-filter="educational">Educational</button>
        </div>
      </div>

      <!-- Grid -->
      <div id="projects-grid">
        <!-- JS will populate this with year groups -->
      </div>
    </section>

    <script src="/js/projects-page.js" defer is:inline></script>
</Layout>
